rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDate(value) {
      return value is string
        && value.matches('^\\d{4}-((01|03|05|07|08|10|12)-(0[1-9]|[12][0-9]|3[01])|(04|06|09|11)-(0[1-9]|[12][0-9]|30)|02-(0[1-9]|1[0-9]|2[0-9]))$');
    }

    function isOptionalDate(value) {
      return value == null || isDate(value);
    }

    function isTime(value) {
      return value is string && (value == '' || value.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$'));
    }

    function isTimestampText(value) {
      return value is string && value.size() >= 10 && value.size() <= 40;
    }

    function createdAtUnchanged() {
      return ('createdAt' in resource.data)
        ? (('createdAt' in request.resource.data) && request.resource.data.createdAt == resource.data.createdAt)
        : !('createdAt' in request.resource.data);
    }

    function validUserProfile() {
      return request.resource.data.keys().hasOnly(['email', 'name', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(['email', 'name', 'updatedAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && isTimestampText(request.resource.data.updatedAt)
        && (!('createdAt' in request.resource.data) || isTimestampText(request.resource.data.createdAt));
    }

    function validNote(noteId) {
      return request.resource.data.keys().hasOnly(['noteDate', 'content', 'updatedAt'])
        && request.resource.data.noteDate == noteId
        && isDate(request.resource.data.noteDate)
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 10000
        && isTimestampText(request.resource.data.updatedAt);
    }

    function validPlan(planId) {
      return request.resource.data.keys().hasOnly(['id', 'planDate', 'timeLabel', 'title', 'details', 'createdAt', 'updatedAt'])
        && request.resource.data.id == planId
        && isDate(request.resource.data.planDate)
        && isTime(request.resource.data.timeLabel)
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 160
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 5000
        && isTimestampText(request.resource.data.createdAt)
        && isTimestampText(request.resource.data.updatedAt);
    }

    function validPortfolioItem(itemId) {
      return request.resource.data.keys().hasOnly(['id', 'type', 'title', 'organization', 'role', 'teammates', 'startDate', 'endDate', 'status', 'achievement', 'links', 'notes', 'createdAt', 'updatedAt'])
        && request.resource.data.id == itemId
        && request.resource.data.type in ['project', 'competition']
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 160
        && request.resource.data.organization is string
        && request.resource.data.organization.size() <= 160
        && request.resource.data.role is string
        && request.resource.data.role.size() <= 160
        && request.resource.data.teammates is string
        && request.resource.data.teammates.size() <= 1000
        && isOptionalDate(request.resource.data.startDate)
        && isOptionalDate(request.resource.data.endDate)
        && (request.resource.data.startDate == null || request.resource.data.endDate == null || request.resource.data.endDate >= request.resource.data.startDate)
        && request.resource.data.status in ['planned', 'active', 'completed']
        && request.resource.data.achievement is string
        && request.resource.data.achievement.size() <= 1000
        && request.resource.data.links is string
        && request.resource.data.links.size() <= 2000
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 5000
        && isTimestampText(request.resource.data.createdAt)
        && isTimestampText(request.resource.data.updatedAt);
    }

    function validTodo(todoId) {
      return request.resource.data.keys().hasOnly(['id', 'title', 'details', 'subtasks', 'dueDate', 'lane', 'sortOrder', 'priority', 'done', 'daily', 'dailyCompletedOn', 'streak', 'createdAt', 'updatedAt'])
        && request.resource.data.id == todoId
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 160
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 5000
        && request.resource.data.subtasks is list
        && request.resource.data.subtasks.size() <= 32
        && isOptionalDate(request.resource.data.dueDate)
        && request.resource.data.lane in ['ideas', 'month', 'week', 'today', 'done']
        && request.resource.data.sortOrder is number
        && request.resource.data.sortOrder >= -1000000000
        && request.resource.data.sortOrder <= 1000000000
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.done is bool
        && request.resource.data.daily is bool
        && (!request.resource.data.daily || (request.resource.data.lane == 'today' && request.resource.data.done == false))
        && isOptionalDate(request.resource.data.dailyCompletedOn)
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && request.resource.data.streak <= 100000
        && isTimestampText(request.resource.data.createdAt)
        && isTimestampText(request.resource.data.updatedAt);
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && validUserProfile();
      allow update: if isOwner(userId) && validUserProfile() && createdAtUnchanged();

      match /notes/{noteId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validNote(noteId);
      }

      match /plans/{planId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validPlan(planId);
        allow update: if isOwner(userId) && validPlan(planId) && createdAtUnchanged();
      }

      match /portfolio/{itemId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validPortfolioItem(itemId);
        allow update: if isOwner(userId) && validPortfolioItem(itemId) && createdAtUnchanged();
      }

      match /todos/{todoId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && validTodo(todoId);
        allow update: if isOwner(userId) && validTodo(todoId) && createdAtUnchanged();
      }
    }
  }
}
